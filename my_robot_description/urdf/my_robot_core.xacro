<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_lx" value="0.25" />
    <xacro:property name="base_ly" value="0.15" />
    <xacro:property name="base_lz" value="0.05" />

    <xacro:property name="wheel_rad" value="0.038" />
    <xacro:property name="wheel_len" value="0.026" />
    <xacro:property name="base_wheel_offset_x" value="${base_lx * 0.3}" />
    <xacro:property name="base_wheel_offset_z" value="0" />

    <xacro:property name="caster_rad" value="0.02" />
    <xacro:property name="base_caster_offset_x" value="${base_lx * 0.4}" />
    <xacro:property name="base_caster_offset_z" value="${-base_lz * 0.5}" />

    <!-- Base -->

    <link name="base_footprint" />

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${base_lx} ${base_ly} ${base_lz}" />
            </geometry>
            <material name="red" />
        </visual>
    </link>

    <joint name="footprint_base_joint" type="fixed">
        <origin xyz="0 0 ${wheel_rad - base_wheel_offset_z}" rpy="0 0 0" />
        <parent link="base_footprint" />
        <child link="base_link" />
    </joint>

    <!-- Wheels -->

    <link name="left_wheel_link">
        <visual name="">
            <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0" />
            <geometry>
                <cylinder radius="${wheel_rad}" length="${wheel_len}" />
            </geometry>
            <material name="black" />
        </visual>
    </link>

    <joint name="base_left_wheel_joint" type="continuous">
        <origin xyz="-${base_wheel_offset_x} ${-(base_ly + wheel_len) / 2} ${base_wheel_offset_z}"
            rpy="0 0 0" />
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <axis xyz="0 1 0"/>
    </joint>

    <link name="right_wheel_link">
        <visual name="">
            <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0" />
            <geometry>
                <cylinder radius="${wheel_rad}" length="${wheel_len}" />
            </geometry>
            <material name="black" />
        </visual>
    </link>

    <joint name="base_right_wheel_joint" type="continuous">
        <origin xyz="-${base_wheel_offset_x} ${(base_ly + wheel_len) / 2} ${base_wheel_offset_z}"
            rpy="0 0 0" />
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <axis xyz="0 1 0"/>
    </joint>

    <!-- Caster -->
    <link name="caster_link">
        <visual>
            <origin xyz="0 0 ${-caster_rad / 2}" rpy="0 0 0" />
            <geometry>
                <sphere radius="${caster_rad}" />
            </geometry>
            <material name="silver" />
        </visual>
    </link>
    
    <joint name="base_caster_joint" type="fixed">
        <origin xyz="${base_caster_offset_x} 0 ${base_caster_offset_z}" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="caster_link"/>
    </joint>

</robot>